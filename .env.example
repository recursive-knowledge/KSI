# -----------------------------------------------------------------------------
# .env.example -- canonical template for ksi configuration overrides
# -----------------------------------------------------------------------------
#
# Copy this file to `.env` at the repo root and edit values as needed:
#
#   cp .env.example .env
#
# `python-dotenv` is loaded automatically at module import time by `ksi/cli.py`
# and by every module that defines a configurable default below. You can also set
# any of these in your shell environment (`export FOO=bar`) -- env vars take
# precedence over `.env` file values.
#
# This file intentionally covers only constants a downstream user of a
# distributable package might reasonably want to override (public URLs, dataset
# names, Docker image tags, model names). Internal tuning constants (retry
# counts, timeouts, char limits, etc.) remain in source and are exposed via
# dedicated CLI flags instead -- see `ksi --help`.
#
# -----------------------------------------------------------------------------
# Credentials (used elsewhere in the codebase; listed here for completeness)
# -----------------------------------------------------------------------------

# Anthropic API key used by agent containers and the orchestrator LLM caller.
# See README.md for provider-profile setup (configs/ksi/.env.haiku).
# ANTHROPIC_API_KEY=sk-ant-...

# HuggingFace token for the gated EmbeddingGemma model used by agent memory
# vector search. Without it, vector search is disabled (FTS-only fallback).
# HF_TOKEN=hf_...

# -----------------------------------------------------------------------------
# Polyglot benchmark (scripts/dataprep/prepare_polyglot_dataset.py)
# -----------------------------------------------------------------------------

# Git URL of the upstream Exercism-style polyglot benchmark repo that the
# dataprep script clones to extract per-exercise metadata.
# POLYGLOT_BENCHMARK_REPO=https://github.com/Aider-AI/polyglot-benchmark.git

# URL (or local path) of the subset JSON file that lists which `lang__exercise`
# task IDs to include in the prepared dataset. Default points at HyperAgents'
# curated medium.json (50 tasks).
# POLYGLOT_SUBSET_URL=https://raw.githubusercontent.com/facebookresearch/HyperAgents/main/domains/polyglot/subsets/medium.json

# Docker image tag used by `ksi.eval.polyglot_harness.PolyglotHarnessEvaluator`
# and built by `ksi.eval.polyglot_docker.build_image()`. Override if you want
# to pin a specific tag or point at a private registry mirror.
# POLYGLOT_DOCKER_IMAGE=ksi-polyglot-eval:latest

# -----------------------------------------------------------------------------
# Agent memory -- embeddings
# -----------------------------------------------------------------------------

# Sentence-transformers model name used by `ksi.memory.embeddings.Embedder`
# for task-summary vectorization. Must match the `dimensions` wired up in the
# store schema (the default model produces 768-dim vectors).
# KSI_EMBEDDING_MODEL=google/embeddinggemma-300m
